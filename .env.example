# ── 应用配置 ──
APP_NAME=my-new-project
APP_ENV=development
APP_PORT=8000

# ── PostgreSQL ──
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── 组合连接串 ──
# 注意：Docker Compose 不会展开 .env 中的 ${VAR} 引用
# 以下连接串供应用代码使用，需要手动填写完整值
# 或在代码中根据 POSTGRES_* 变量动态拼接
DATABASE_URL=postgresql://app:change_me_in_production@127.0.0.1:5432/appdb
REDIS_URL=redis://127.0.0.1:6379/0

# ── Docker Compose ──
COMPOSE_PROJECT_NAME=app

# ── AI Provider Keys（留空表示不启用）──
# AI provider keys are intentionally left blank.
# Fill in only the provider(s) you actually use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
